// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// MODEL 1: USER (Menyimpan data login Google)
model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  googleId  String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relasi One-to-Many: Satu user bisa punya banyak bisnis
  businesses Business[]
}

// MODEL 2: BUSINESS (Data bisnis dari Google Maps)
model Business {
  id           String   @id @default(uuid())
  
  // Foreign Key untuk menghubungkan ke User
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name         String
  location     String
  primaryCat   String
  totalReviews Int
  avgRating    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relasi ke tabel Task dan Score History
  tasks        Task[]
  scoreHistory ScoreHistory[]
}

// MODEL 3: SCORE HISTORY (Menyimpan riwayat peringkat)
model ScoreHistory {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  score      Int
  rank       Int
  createdAt  DateTime @default(now())
}

// MODEL 4: TASK (Menyimpan AI Action Plan)
model Task {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  description String
  impactScore Int
  isCompleted Boolean  @default(false) // Untuk menyimpan status checklist
  createdAt   DateTime @default(now())
}